{
  "name": "@gsd/pi-ai",
  "version": "2.74.0",
  "description": "Unified LLM API (vendored from pi-mono)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
