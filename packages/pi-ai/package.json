    "@mistralai/mistralai": "^1.14.1",
    "@sinclair/typebox": "^0.34.41",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "chalk": "^5.6.2",
    "openai": "^6.26.0",
    "proxy-agent": "^6.5.0",
    "undici": "^7.24.2",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@smithy/node-http-handler": "^4.5.0"
